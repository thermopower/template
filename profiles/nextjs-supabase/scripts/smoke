#!/usr/bin/env bash
# Next.js + Supabase profile smoke test
# 빌드 성공 여부와 환경변수 존재 여부를 확인합니다.

set -e

APP_DIR="${APP_DIR:-app}"
[ -d "src" ] && APP_DIR="src"

echo "[smoke:nextjs-supabase] smoke test 시작..."
FAILED=0

# 1. 필수 환경변수 확인
REQUIRED_VARS=(
  "NEXT_PUBLIC_SUPABASE_URL"
  "NEXT_PUBLIC_SUPABASE_ANON_KEY"
)

for VAR in "${REQUIRED_VARS[@]}"; do
  if [ -z "${!VAR}" ]; then
    # .env.local 또는 .env에서 확인
    if grep -q "^${VAR}=" .env.local 2>/dev/null || grep -q "^${VAR}=" .env 2>/dev/null; then
      echo "[smoke:nextjs-supabase] $VAR: .env 파일에 존재"
    else
      echo "[smoke:nextjs-supabase] WARNING: $VAR 환경변수 없음 (런타임 오류 가능)" >&2
    fi
  else
    echo "[smoke:nextjs-supabase] $VAR: OK"
  fi
done

# 2. TypeScript 타입 체크
if [ -f "tsconfig.json" ] && command -v npx >/dev/null 2>&1; then
  echo "[smoke:nextjs-supabase] TypeScript 타입 체크..."
  if npx tsc --noEmit 2>&1; then
    echo "[smoke:nextjs-supabase] tsc PASS"
  else
    echo "[smoke:nextjs-supabase] tsc FAIL" >&2
    FAILED=1
  fi
fi

# 3. Next.js 빌드
if [ -f "package.json" ] && command -v npm >/dev/null 2>&1; then
  echo "[smoke:nextjs-supabase] Next.js 빌드..."
  if npm run build 2>&1; then
    echo "[smoke:nextjs-supabase] build PASS"
  else
    echo "[smoke:nextjs-supabase] build FAIL" >&2
    FAILED=1
  fi
fi

# 4. stub/placeholder 검사
echo "[smoke:nextjs-supabase] stub/placeholder 검사..."
STUB_HITS=$(grep -rn "TODO\|FIXME\|stub\|placeholder\|not implemented" "$APP_DIR" 2>/dev/null || true)
if [ -n "$STUB_HITS" ]; then
  echo "[smoke:nextjs-supabase] stub/placeholder 발견:" >&2
  echo "$STUB_HITS" >&2
  FAILED=1
else
  echo "[smoke:nextjs-supabase] stub 검사 PASS"
fi

if [ $FAILED -eq 0 ]; then
  echo "[smoke:nextjs-supabase] 모든 검사 통과."
  exit 0
else
  exit 1
fi
