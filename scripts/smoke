#!/usr/bin/env bash
# smoke test runner
# profile이 설정되지 않은 경우 skip합니다.

PROFILE_SCRIPT="profiles/$(cat .claude-state/sprint-contract.md 2>/dev/null | grep '^profile:' | awk '{print $2}')/scripts/smoke"

if [ ! -f "$PROFILE_SCRIPT" ]; then
  # profile 없이도 동작 가능한 기본 smoke: 앱 디렉토리 존재 여부만 확인
  if [ -d "app" ] || [ -d "src" ]; then
    echo "[smoke] SKIP - profile이 설정되지 않았습니다."
    echo "[smoke] profiles/<stack>/scripts/smoke 를 구현하면 실제 smoke test가 실행됩니다."
    exit 0
  else
    echo "[smoke] SKIP - profile 없음, app/src 디렉토리 없음"
    exit 0
  fi
fi

echo "[smoke] profile smoke 실행: $PROFILE_SCRIPT"
bash "$PROFILE_SCRIPT"
