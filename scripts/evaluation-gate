#!/usr/bin/env bash
# evaluation-gate: smoke + unit 실행 후 종합 pass/fail 판정
# sprint-contract.md의 acceptance criteria 기준으로 판정합니다.
# profile 독립적으로 동작합니다.

set -euo pipefail

REPORT=".claude-state/evaluation-report.md"
CONTRACT=".claude-state/sprint-contract.md"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

SMOKE_RESULT="SKIP"
UNIT_RESULT="SKIP"
STUB_RESULT="PASS"
OVERALL="pass"
BLOCKERS=()

echo "=== evaluation-gate 시작: $TIMESTAMP ==="

# 1. smoke 실행
echo "[1/3] smoke test 실행..."
if bash scripts/smoke; then
  SMOKE_RESULT="PASS"
else
  SMOKE_RESULT="FAIL"
  OVERALL="fail"
  BLOCKERS+=("smoke test 실패")
fi

# 2. unit 실행
echo "[2/3] unit test 실행..."
if bash scripts/unit; then
  UNIT_RESULT="PASS"
else
  UNIT_RESULT="FAIL"
  OVERALL="fail"
  BLOCKERS+=("unit test 실패")
fi

# 3. stub/placeholder 잔존 검사 (app/ 또는 src/ 디렉토리)
echo "[3/3] stub/placeholder 잔존 검사..."
SEARCH_DIRS=""
[ -d "app" ] && SEARCH_DIRS="app"
[ -d "src" ] && SEARCH_DIRS="$SEARCH_DIRS src"

if [ -n "$SEARCH_DIRS" ]; then
  STUB_HITS=$(grep -rn "TODO\|FIXME\|stub\|placeholder\|not implemented\|NotImplemented" $SEARCH_DIRS 2>/dev/null || true)
  if [ -n "$STUB_HITS" ]; then
    STUB_RESULT="FAIL"
    OVERALL="fail"
    BLOCKERS+=("핵심 경로에 stub/placeholder 잔존")
    echo "[stub] 발견된 stub:"
    echo "$STUB_HITS"
  else
    STUB_RESULT="PASS"
  fi
fi

# 4. evaluation-report.md 작성
BLOCKER_TEXT="없음"
if [ ${#BLOCKERS[@]} -gt 0 ]; then
  BLOCKER_TEXT=$(printf "- %s\n" "${BLOCKERS[@]}")
fi

cat > "$REPORT" << EOF
# Evaluation Report

status: $OVERALL

updated: $TIMESTAMP

---

## 실행 환경

$(uname -a 2>/dev/null || echo "unknown")

## 검증 항목

| 항목 | 결과 |
|---|---|
| smoke test | $SMOKE_RESULT |
| unit test | $UNIT_RESULT |
| stub 잔존 검사 | $STUB_RESULT |

## 판정

**결과**: $OVERALL

**판정 근거**: 위 검증 항목 기준으로 판정. acceptance criteria는 sprint-contract.md 참조.

## Blocker

$BLOCKER_TEXT

## Regression

별도 확인 필요
EOF

echo "=== evaluation-gate 완료: $OVERALL ==="
echo "결과가 $REPORT 에 기록되었습니다."

if [ "$OVERALL" = "fail" ]; then
  exit 1
fi
exit 0
