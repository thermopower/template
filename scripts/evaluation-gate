#!/usr/bin/env bash
# evaluation-gate: smoke + unit 실행 후 종합 pass/fail 판정
# evaluator가 호출하는 게이트 스크립트. 결과는 stdout으로 출력하며,
# evaluation-report.md는 evaluator가 직접 작성한다 (이 스크립트는 덮어쓰지 않음).

set -o pipefail

TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

SMOKE_RESULT="SKIP"
UNIT_RESULT="SKIP"
STUB_RESULT="PASS"
AUDIT_RESULT="SKIP"
OVERALL="pass"
BLOCKERS=()

echo "=== evaluation-gate 시작: $TIMESTAMP ==="

# 1. smoke 실행
echo "[1/3] smoke test 실행..."
if bash scripts/smoke 2>&1; then
  SMOKE_RESULT="PASS"
else
  SMOKE_RESULT="FAIL"
  OVERALL="fail"
  BLOCKERS+=("smoke test 실패")
fi

# 2. unit 실행 (파일이 있을 때만)
echo "[2/3] unit test 실행..."
if [ -f "scripts/unit" ]; then
  if bash scripts/unit 2>&1; then
    UNIT_RESULT="PASS"
  else
    UNIT_RESULT="FAIL"
    OVERALL="fail"
    BLOCKERS+=("unit test 실패")
  fi
else
  echo "[2/3] scripts/unit 없음. 건너뜀."
  UNIT_RESULT="SKIP"
fi

# 3. stub/placeholder 잔존 검사
echo "[3/3] stub/placeholder 잔존 검사..."
SEARCH_DIRS=""
[ -d "app" ] && SEARCH_DIRS="app"
[ -d "src" ] && SEARCH_DIRS="$SEARCH_DIRS src"

if [ -n "$SEARCH_DIRS" ]; then
  STUB_HITS=$(grep -rn \
    --include="*.ts" --include="*.tsx" --include="*.js" --include="*.jsx" \
    --include="*.py" --include="*.go" \
    --exclude-dir="__tests__" --exclude-dir="node_modules" --exclude-dir=".next" \
    --exclude-dir=".git" --exclude-dir="dist" --exclude-dir="build" \
    --exclude="*.test.ts" --exclude="*.test.tsx" --exclude="*.test.js" \
    --exclude="*.spec.ts" --exclude="*.spec.tsx" --exclude="*.spec.js" \
    --exclude="test_*.py" --exclude="*_test.go" \
    "TODO\|FIXME\|stub\|placeholder\|not implemented\|NotImplemented" \
    $SEARCH_DIRS 2>/dev/null \
    | grep -v "^[^:]*:[0-9]*:[[:space:]]*//" \
    | grep -v "^[^:]*:[0-9]*:[[:space:]]*#" \
    | grep -v "^[^:]*:[0-9]*:[[:space:]]*\*" \
    || true)
  if [ -n "$STUB_HITS" ]; then
    STUB_RESULT="FAIL"
    OVERALL="fail"
    BLOCKERS+=("핵심 경로에 stub/placeholder 잔존")
    echo "[stub] 발견:"
    echo "$STUB_HITS"
  else
    STUB_RESULT="PASS"
  fi
fi

# 4. npm audit (high 이상 취약점 검사)
echo "[4/4] npm audit 실행..."
if [ -f "package.json" ] && command -v npm >/dev/null 2>&1; then
  AUDIT_OUTPUT=$(npm audit --audit-level=high 2>&1)
  AUDIT_EXIT=$?
  echo "$AUDIT_OUTPUT"
  if [ $AUDIT_EXIT -eq 0 ]; then
    AUDIT_RESULT="PASS"
  else
    AUDIT_RESULT="FAIL"
    OVERALL="fail"
    BLOCKERS+=("npm audit high 이상 취약점 발견")
  fi
else
  echo "[4/4] package.json 없음 또는 npm 없음. 건너뜀."
  AUDIT_RESULT="SKIP"
fi

# 5. 결과 출력 (evaluator가 이 출력을 읽어 evaluation-report.md를 작성)
echo ""
echo "=== evaluation-gate 결과 ==="
echo "overall: $OVERALL"
echo "smoke: $SMOKE_RESULT"
echo "unit: $UNIT_RESULT"
echo "stub: $STUB_RESULT"
echo "audit: $AUDIT_RESULT"
if [ ${#BLOCKERS[@]} -gt 0 ]; then
  echo "blockers:"
  for b in "${BLOCKERS[@]}"; do
    echo "  - $b"
  done
fi
echo "=== evaluation-gate 완료 ==="

if [ "$OVERALL" = "fail" ]; then
  exit 1
fi
exit 0
